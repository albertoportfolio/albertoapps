---
import { projects, site } from "../data/site";
---

<section id="proyectos" class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="section-kicker">Portfolio</span>
      <h2 class="section-title">Proyectos destacados</h2>
      <p class="section-sub">
        Una selección de apps y webs que he desarrollado. Puedes ver el código
        en mi GitHub.
      </p>
    </div>

    <div class="projects-grid">
      {projects.map((p, i) => (
        <article class="card project-card reveal" style={`--rd: ${i * 0.08}s`}>
          <div class="project-top">
            <span class="project-folder" aria-hidden="true">📂</span>
            <div class="project-links">
              <a href={p.repo} target="_blank" rel="noopener noreferrer">
                Código ↗
              </a>
              {p.demo && (
                <a href={p.demo} target="_blank" rel="noopener noreferrer">
                  Demo ↗
                </a>
              )}
            </div>
          </div>
          <h3>{p.title}</h3>
          <p>{p.description}</p>
          <div class="tags">
            {p.tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="projects-cta reveal reveal-fade" style="--rd: 0.2s">
      <a
        href={site.github}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost"
      >
        Ver más en GitHub →
      </a>
    </div>
  </div>
</section>
